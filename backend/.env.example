# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env file. It stays only on your machine.

# --- Groq (generation: writes the answers) ---
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# --- Google Gemini (embeddings: turns text into vectors for search) ---
# Get a free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-key-here

# --- MongoDB Atlas ---
# Atlas cluster: Connect -> Drivers -> copy string, replace <password>.
MONGODB_URI=mongodb+srv://user:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Names (fine to leave as-is)
MONGODB_DB=guidance_bot
MONGODB_COLLECTION=guidance_chunks
ATLAS_VECTOR_INDEX=guidance_vector_index

PORT=4000
